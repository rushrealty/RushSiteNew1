# Repliers API Configuration
# Get your API key from https://repliers.com
REPLIERS_API_KEY=your_repliers_api_key_here

# Google Maps API Configuration
# Required for Schools and Nearby Places features
# Enable these APIs: Places API, Geocoding API, Distance Matrix API
GOOGLE_MAPS_API_KEY=AIzaSyCr7oXHFPoN5UsFynxNcR6w_G2YfJ-FE2w
# Client-side Google Maps (for address autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCr7oXHFPoN5UsFynxNcR6w_G2YfJ-FE2w

# Google Sheets Configuration
# To publish your sheet: File > Share > Publish to web > Select "Entire Document" > Publish
# The SHEET_ID is in the URL after /d/e/ when you publish (e.g., 2PACX-1vXXXXXX...)
NEXT_PUBLIC_GOOGLE_SHEET_ID=2PACX-1vQq5kKLZrq1Ror-1rXh_krZnhcs_V1ssIm4uykHjgURw-Y4j2k-RrteDMqfvod9OkHu4hofA071UOJo/pubhtml

# Tab GIDs - Find these by clicking each tab in your Google Sheet
# The GID appears in the URL as &gid=XXXXXXX
# Click on Builders tab and copy the gid from the URL
NEXT_PUBLIC_SHEET_GID_BUILDERS=0#gid=0
# Click on Communities tab and copy the gid from the URL
NEXT_PUBLIC_SHEET_GID_COMMUNITIES=1651556845
# Click on Inventory tab and copy the gid from the URL
NEXT_PUBLIC_SHEET_GID_INVENTORY=1527336354

# Formspree Configuration
# Get your form endpoint from https://formspree.io
# Create a form and copy the endpoint URL (e.g., https://formspree.io/f/xyzabc123)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xpqwbwgn

# Follow Up Boss (FUB) CRM Configuration
# Get your API key from Follow Up Boss: Admin > API
